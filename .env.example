NODE_ENV=
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
OPENAI_API_KEY=
JWT_SECRET=

MICROSOFT_BUILDINGS_DATA_PATH=
OVERTURE_DATA_PATH=
LOCAL_BUILDINGS_DATA_PATH=
CITY_GEOJSON_DATA_PATH=
OPEN_TOPOGRAPHY_API_KEY=
OPEN_TOPOGRAPHY_DEM_TYPE=COP30
OPEN_TOPOGRAPHY_MAX_SAMPLES=4096
OPEN_TOPOGRAPHY_CACHE_PATH=
OPEN_TOPOGRAPHY_CACHE_DISABLED=0
OPEN_TOPOGRAPHY_SPLIT_LARGE_REQUESTS=0

NEXT_PUBLIC_MICROSOFT_BUILDINGS_API_URL=/api/data/microsoft-buildings

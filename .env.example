NEXT_PUBLIC_CITY_GEOJSON_API_URL=/api/data/city-geojson
NEXT_PUBLIC_OPEN_TOPOGRAPHY_API_URL=/api/data/opentopography
# Optional DEM fallbacks. Each endpoint must return the same GeoJSON contract
# as /api/data/opentopography (FeatureCollection<Point> + metadata).
NEXT_PUBLIC_NASA_SRTM_API_URL=
NEXT_PUBLIC_OPEN_ELEVATION_API_URL=/api/data/open-elevation
NEXT_PUBLIC_ASTER_GDEM_API_URL=
NEXT_PUBLIC_MAPBOX_TERRAIN_API_URL=
NEXT_PUBLIC_OPEN_AERIAL_MAP_API_URL=
NEXT_PUBLIC_NATIONAL_GEOSPATIAL_PORTAL_API_URL=
